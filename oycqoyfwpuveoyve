local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

local function antiLoopKill()
    local Character = LocalPlayer.Character
    if Character then
        local Humanoid = Character:FindFirstChildOfClass("Humanoid")
        local RootPart = Character:FindFirstChild("HumanoidRootPart")
        
        if RootPart and Humanoid and Humanoid.Health > 0 then
            -- 캐릭터가 날아가는 것을 방지하기 위해 속도를 0으로 설정
            RootPart.Velocity = Vector3.new(0, 0, 0)
            RootPart.RotVelocity = Vector3.new(0, 0, 0)
        end
    end
end

-- 렌더링 주기에 맞춰 루프 실행
local connection
connection = RunService.RenderStepped:Connect(antiLoopKill)

-- 필요 시 루프 해제용 함수
local function stopAntiLoopKill()
    if connection then
        connection:Disconnect()
    end
end
local function disableGrabDetection()
    local Character = LocalPlayer.Character
    if Character then
        for _, part in pairs(Character:GetChildren()) do
            if part:IsA("BasePart") and (part.Name == "GrabPart" or part.Name == "Blobman") then
                part.CanCollide = false
            end
        end
    end
end

RunService.Heartbeat:Connect(disableGrabDetection)
