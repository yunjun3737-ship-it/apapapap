local function initializeRobustDefense()
    local function applyDefense(char)
        local hum = char:WaitForChild("Humanoid", 10)
        local rootPart = char:WaitForChild("HumanoidRootPart", 10)

        if hum then
            pcall(function()
                hum.MaxHealth = math.huge
                hum.Health = math.huge
            end)

            local healthChangedConnection
            healthChangedConnection = hum:GetPropertyChangedSignal("Health"):Connect(function()
                local currentHealth = hum.Health
                if currentHealth <= 0 or currentHealth < math.huge then
                    pcall(function()
                        hum.Health = math.huge
                    end)
                end
            end)

            hum.Died:Connect(function()
                if healthChangedConnection then
                    healthChangedConnection:Disconnect()
                end
                task.wait(2.5)
                if LocalPlayer.Character then
                    applyDefense(LocalPlayer.Character)
                end
            end)
        end

        RunService.Heartbeat:Connect(function()
            if char and rootPart and hum and hum.Health > 0 then
                local currentVelocity = rootPart.Velocity
                if math.abs(currentVelocity.Y) > 250 then
                    rootPart.Velocity = Vector3.new(currentVelocity.X, -30, currentVelocity.Z)
                end

                for _, part in pairs(char:GetChildren()) do
                    if part:IsA("BasePart") and (part.Name == "GrabPart" or part.Name == "Blobman") then
                        part.CanCollide = false
                    end
                end
            end
        end)
    end

    if LocalPlayer.Character then
        applyDefense(LocalPlayer.Character)
    end
    LocalPlayer.CharacterAdded:Connect(applyDefense)
end

